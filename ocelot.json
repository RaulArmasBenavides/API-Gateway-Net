{
  "Routes": [
    {
      "DownstreamPathTemplate": "/swagger/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44340
        }
      ],
      "UpstreamPathTemplate": "/movies/swagger/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "movies"
    },
    {
      "DownstreamPathTemplate": "/api/v1/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44340
        }
      ],
      "UpstreamPathTemplate": "/movies/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 5,
        "ClientWhitelist": []
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7090",
    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "QuotaExceededMessage": "Too many requests. Please try again later.",
      "HttpStatusCode": 429,
      "DisableRateLimitHeaders": false
    }
  }
}
