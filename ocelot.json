{
  "Routes": [
    {
      "DownstreamPathTemplate": "/swagger/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44340
        }
      ],
      "UpstreamPathTemplate": "/movies/swagger/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "movies",
      "RateLimitOptions": {
        "EnableRateLimiting": false
      }
    },
    {
      "DownstreamPathTemplate": "/api/v1/Categories",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44340
        }
      ],
      "UpstreamPathTemplate": "/movies/Categories",
      "UpstreamHttpMethod": [ "GET" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 30,
        "ClientWhitelist": []
      }
    },
    {
      "DownstreamPathTemplate": "/api/v1/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 44340
        }
      ],
      "UpstreamPathTemplate": "/movies/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 15,
        "ClientWhitelist": []
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7090",
    "RateLimitOptions": {
      "ClientIdHeader": "X-ClientId",
      "QuotaExceededMessage": "Límite de solicitudes excedido. Intenta más tarde.",
      "HttpStatusCode": 429,
      "DisableRateLimitHeaders": false,
      "RateLimitCounterPrefix": "ocelot"
    },
    "ServiceDiscoveryProvider": {
      "Type": "Consul",
      "Host": "localhost",
      "Port": 8500,
      "PollingInterval": 10000
    }
  }
}
